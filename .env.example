# Copy this file to .env on the server, then fill in real mailbox credentials.
# Do not commit .env to GitHub.

# The mailbox that receives website inquiries. Multiple recipients can be comma-separated.
LEAD_EMAIL_TO=wang2797545062@gmail.com

# Optional sender shown in email clients.
LEAD_EMAIL_FROM="向量跃迁官网 <your-mailbox@example.com>"

# SMTP example for Gmail. Gmail requires an App Password, not your normal login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-mailbox@gmail.com
SMTP_PASS=your-app-password
